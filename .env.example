PORT=3000
DATABASE_URL=postgresql://weather_user:weather_pass@localhost:5432/weather_llm?schema=public
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_BASE_URL=http://ai-hub.local
OLLAMA_CHAT_MODEL=qwen3:1.7b
OLLAMA_TIMEOUT_MS=30000
NWS_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
NWS_EMBEDDING_TIMEOUT_MS=30000
NWS_EMBEDDING_CACHE_DIR=.cache/transformers
NWS_ANSWER_TIMEOUT_MS=120000
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NWS_ALERTS=nws_alerts_embeddings_v1
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_MS=30000
QDRANT_VECTOR_SIZE=384
NWS_INGEST_MAX_BATCH_SIZE=100
NWS_INGEST_MAX_TEXT_CHARS=12000
NWS_ALERTS_DB_HOST=localhost
NWS_ALERTS_DB_PORT=3307
NWS_ALERTS_DB_USER=emwin_user
NWS_ALERTS_DB_PASSWORD=emwin_pass
NWS_ALERTS_DB_NAME=emwin
NWS_ALERTS_BACKFILL_BATCH_DEFAULT=500
NWS_ALERTS_BACKFILL_BATCH_MAX=5000
NWS_SEARCH_TOPK_DEFAULT=12
NWS_SEARCH_TOPK_MAX=20
NWS_SEARCH_CANDIDATE_MULTIPLIER=3
NWS_SEARCH_CANDIDATE_TOPK_MAX=60
NWS_SEARCH_MIN_RELATIVE_SCORE=0.9
# Optional absolute score floor; leave unset to disable
# NWS_SEARCH_MIN_ABSOLUTE_SCORE=0.7
NWS_ANSWER_MAX_CONTEXT_CHARS=6000
NWS_ANSWER_TEMPERATURE=0.2
NWS_ANSWER_MAX_TOKENS=400
# Allowed: bypass | heuristic-v1 | rules-v2 | llm-v1
NWS_CONSTRAINT_EXTRACTOR_DEFAULT=bypass
NWS_CONSTRAINT_EXTRACTOR_ENABLED=false
NWS_CONSTRAINT_EXTRACTOR_TIMEOUT_MS=15000
